# Copy to .env and adjust as needed. In Docker Compose, these will be
# injected automatically and HOST values will be service names
# (e.g. MYSQL_HOST=mysql, REDIS_HOST=redis) instead of 127.0.0.1.

# --- MySQL ---
MYSQL_HOST=127.0.0.1
MYSQL_PORT=3306
MYSQL_USER=collabapp
MYSQL_PASSWORD=collabpass
MYSQL_DATABASE=collab_terminal

# --- Redis ---
REDIS_HOST=127.0.0.1
REDIS_PORT=6379

# --- Auth ---
JWT_SECRET=change-this-in-production

# --- Server ---
PORT=3000
